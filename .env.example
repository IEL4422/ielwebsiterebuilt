# ── Meta Pixel / Conversions API ────────────────────────────────────────────
# Everything Meta-related is INERT until these are set. With NEXT_PUBLIC_FB_PIXEL_ID
# unset, no pixel script loads, no fbq call is made, and /api/meta-capi returns 204.

# Browser pixel. Set this to the "Illinois Estate Law" pixel ID from Events Manager.
NEXT_PUBLIC_FB_PIXEL_ID=

# Conversions API (server-side, optional but recommended). Both are required for CAPI.
# META_PIXEL_ID defaults to NEXT_PUBLIC_FB_PIXEL_ID if omitted.
META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=

# Set temporarily while validating in Events Manager > Test Events. Remove after.
META_CAPI_TEST_EVENT_CODE=
